<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<fragment xmlns="http://jmix.io/schema/flowui/fragment">
    <data>
        <instance id="productCategoryDc"
                  class="io.jmix.bookstore.product.ProductCategory">
            <fetchPlan extends="_base"/>
            <loader/>
        </instance>
    </data>
    <content>
        <vbox id="root" padding="false">
            <formLayout id="form"
                        dataContainer="productCategoryDc">
                <responsiveSteps>
                    <responsiveStep minWidth="0" columns="1"/>
                </responsiveSteps>
                <textField id="nameField" property="name"/>
                <textArea id="descriptionField" minRows="3" maxRows="3" property="description"/>
            </formLayout>
            <hbox id="detailActions">
                <button id="saveButton" text="msg:///actions.Save" themeNames="primary"/>
                <button id="cancelButton" text="msg:///actions.Cancel"/>
            </hbox>
        </vbox>
    </content>
</fragment>